{
  "manifest_version": 3,
  "name": "Time Wasted Tracker",
  "version": "1.0",
  "description": "Analyze your browsing habits and see how much time you spend on different websites.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Wasted Tracker"
  }
}
